{
  "rules": {
    "color-named": "never",
    "color-no-invalid-hex": true,
    "declaration-property-value-disallowed-list": [
      {
        "color":            ["/^#/", "/^rgb/", "/^hsl/"],
        "background-color": ["/^#/", "/^rgb/", "/^hsl/"],
        "border-color":     ["/^#/", "/^rgb/", "/^hsl/"],
        "outline-color":    ["/^#/", "/^rgb/", "/^hsl/"],
        "fill":             ["/^#/", "/^rgb/", "/^hsl/"],
        "stroke":           ["/^#/", "/^rgb/", "/^hsl/"],
        "font-family":      ["/^[\"']/", "/^[A-Z][a-z]/"],
        "font-size":        ["/^[0-9]/"],
        "font-weight":      ["/^[0-9]/"],
        "border-radius":    ["/^[1-9][0-9]*px/"],
        "gap":              ["/^[0-9]/"],
        "padding-top":      ["/^[0-9]/"],
        "padding-right":    ["/^[0-9]/"],
        "padding-bottom":   ["/^[0-9]/"],
        "padding-left":     ["/^[0-9]/"],
        "margin-top":       ["/^[0-9]/"],
        "margin-right":     ["/^[0-9]/"],
        "margin-bottom":    ["/^[0-9]/"],
        "margin-left":      ["/^[0-9]/"],
        "width":            ["/^[0-9]/"],
        "height":           ["/^[0-9]/"],
        "min-width":        ["/^[0-9]/"],
        "border-top":       ["/^[0-9]/"],
        "border-bottom":    ["/^[0-9]/"],
        "border-left":      ["/^[0-9]/"],
        "border-right":     ["/^[0-9]/"]
      },
      {
        "message": "Use a design token (var(--...)) instead of a hardcoded value"
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/styles/**/*.css", "src/app/globals.css"],
      "rules": {
        "color-named": null,
        "color-no-invalid-hex": null,
        "declaration-property-value-disallowed-list": null
      }
    }
  ]
}
